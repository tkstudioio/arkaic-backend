{
  "info": {
    "_postman_id": "arkaic-backend-api",
    "name": "Arkaic Backend API",
    "description": "Marketplace escrow Bitcoin su Ark (mutinynet)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pubkey\": \"02abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890\",\n  \"username\": \"alice\",\n  \"signature\": \"deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new account or update username (requires Schnorr signature over 'username pubkey')"
          }
        },
        {
          "name": "Request Challenge",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pubkey\": \"02abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/challenge",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "challenge"]
            },
            "description": "Request a challenge (nonce) valid for 30 seconds to sign for login"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pubkey\": \"02abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890\",\n  \"nonce\": \"1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef\",\n  \"signature\": \"deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Complete login with nonce and signature. Returns JWT token valid for 1 hour."
          }
        }
      ]
    },
    {
