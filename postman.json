            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            },
            "description": "List all root-level categories (top level of the hierarchy). Root categories have no parent (childrenOf is null)."
          }
        },
        {
          "name": "Get Category by Slug",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categories/electronics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "electronics"]
            },
            "description": "Get details of a specific category, its direct children, and its attributes. Example slug: 'electronics', 'clothing', 'shoes', 'phones', 'laptops', 'bags'"
          }
        }
      ]
    },
    {
      "name": "Listings",
      "item": [
        {
          "name": "Create Listing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 15 Pro Max\",\n  \"price\": 50000,\n  \"description\": \"Brand new, sealed in original packaging.\",\n  \"categoryId\": 2,\n  \"attributes\": [\n    { \"attributeId\": 1, \"valueId\": 20 },\n    { \"attributeId\": 2, \"valueBool\": true },\n    { \"attributeId\": 3, \"valueText\": \"Pristine condition, never opened\" },\n    { \"attributeId\": 5, \"valueText\": \"0.22\" },\n    { \"attributeId\": 7, \"valueIds\": [10, 12] },\n    { \"attributeId\": 8, \"valueText\": \"2024-02-15\" }\n  ],\n  \"signature\": \"deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/listings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings"]
            },
            "description": "Create a new listing (requires Bearer token + Schnorr signature). Supports optional categoryId and attributes. Attribute fields: valueId (select), valueBool (boolean), valueText (text/range/date), valueIds (multi_select)"
          }
        },
        {
          "name": "Update Listing",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Item Name\",\n  \"price\": 6000,\n  \"description\": \"Updated description of the item.\",\n  \"categoryId\": 3,\n  \"attributes\": [\n    { \"attributeId\": 4, \"valueId\": 30 },\n    { \"attributeId\": 5, \"valueBool\": false },\n    { \"attributeId\": 6, \"valueText\": \"Updated condition notes\" },\n    { \"attributeId\": 7, \"valueText\": \"15.5\" },\n    { \"attributeId\": 8, \"valueIds\": [40, 42] }\n  ],\n  \"signature\": \"deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/listings/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings", "1"]
            },
            "description": "Update an existing listing (name, price, description, category, attributes). Only seller can update. Same attribute field format as Create."
          }
        },
        {
          "name": "List All Listings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/listings?limit=20&offset=0&categoryId=2&minPrice=5000&maxPrice=50000&search=&sort=newest&includeChildren=false&attr_1=20&attr_2=true&attr_5=10,100&attr_7=10&attr_7=12",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "categoryId",
                  "value": "2",
                  "disabled": true
                },
                {
                  "key": "minPrice",
                  "value": "5000",
                  "disabled": true
                },
                {
                  "key": "maxPrice",
                  "value": "50000",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "sort",
                  "value": "newest",
                  "disabled": true
                },
                {
                  "key": "includeChildren",
                  "value": "false",
                  "disabled": true
                },
                {
                  "key": "attr_1",
                  "value": "20",
                  "disabled": true
                },
                {
                  "key": "attr_2",
                  "value": "true",
                  "disabled": true
                },
                {
                  "key": "attr_5",
                  "value": "10,100",
                  "disabled": true
                },
                {
                  "key": "attr_7",
                  "value": "10",
                  "disabled": true
                },
                {
                  "key": "attr_7",
                  "value": "12",
                  "disabled": true
                }
              ]
            },
            "description": "List all listings except own (paginated, excludes active escrows). Supports: categoryId, minPrice/maxPrice, search, sort (newest/oldest/price_asc/price_desc), includeChildren, and attribute filters (attr_<id>=<valueId> for select/multi_select, attr_<id>=true|false for boolean, attr_<id>=<min>,<max> for range)"
          }
        },
        {
          "name": "My Listings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/listings/my-listings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings", "my-listings"]
            },
            "description": "List all listings created by authenticated user"
          }
        },
        {
          "name": "Get Listing by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/listings/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings", "1"]
            },
            "description": "Get details of a specific listing with photos (ordered by position). Visible only to seller or active buyer (if active escrow exists)"
          }
        },
        {
          "name": "Get My Purchases",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/listings/my-purchases",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings", "my-purchases"]
            },
            "description": "List all listings purchased by authenticated user (completed escrows only)"
          }
        },
        {
          "name": "Upload Photos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "photos",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/listings/1/photos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings", "1", "photos"]
            },
            "description": "Upload photos to a listing (multipart/form-data). Max 10 photos per listing, max 4MB per file. Only seller can upload. Supports: image/jpeg, image/png, image/webp, image/gif"
          }
        },
        {
          "name": "Delete Photo",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/listings/1/photos/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings", "1", "photos", "1"]
            },
            "description": "Delete a photo from a listing. Only seller can delete. Automatically reorders remaining photos."
          }
        },
        {
          "name": "Reorder Photos",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"photoIds\": [3, 1, 2]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/listings/1/photos/order",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings", "1", "photos", "order"]
            },
            "description": "Reorder photos by providing array of photoIds in desired order. Must include all existing photo IDs. Only seller can reorder."
          }
        },
        {
          "name": "Get Photo Presigned URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/listings/1/photos/1/url",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings", "1", "photos", "1", "url"]
            },
            "description": "Get a presigned URL for secure, time-limited access to a photo stored in MinIO. URL is valid for 1 hour and does not require authentication or MinIO credentials."
          }
        }
      ]
    },
