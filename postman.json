            ],
            "url": {
              "raw": "{{baseUrl}}/api/attributes/filters/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attributes", "filters", "2"]
            },
            "description": "Get filterable attributes with DISTINCT values from actual listings in category"
