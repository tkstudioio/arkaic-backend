    {
      "name": "Collaborative Path",
      "item": [
        {
          "name": "Seller: Get PSBT",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/escrows/address/tark1xxxxxxxxxxxxxxxxxxxxxxxxxxxxx/collaborate/seller-psbt",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "escrows",
                "address",
                "tark1xxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
                "collaborate",
                "seller-psbt"
              ]
            },
            "description": "Seller requests PSBT to sign"
          }
        },
        {
          "name": "Seller: Submit Signed PSBT",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signedPsbt\": \"cHNidP8BAAAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/escrows/address/tark1xxxxxxxxxxxxxxxxxxxxxxxxxxxxx/collaborate/seller-submit-psbt",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "escrows",
                "address",
                "tark1xxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
                "collaborate",
                "seller-submit-psbt"
              ]
            },
            "description": "Seller submits signed PSBT"
          }
