// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  pubkey    String   @id
  username  String
  createdAt DateTime @default(now())
  isArbiter Boolean  @default(false)

  listings        Listing[]
  buyerChats      Chat[]    @relation("ChatBuyer")
  arbiterChats    Chat[]    @relation("ChatArbiter")
  messages        Message[]
  buyerEscrows    Escrow[]  @relation("EscrowBuyer")
  sellerEscrows   Escrow[]  @relation("EscrowSeller")
  arbiterEscrows  Escrow[]  @relation("EscrowArbiter")
  reviewsReceived Review[]  @relation("ReviewReceived")
  reviewsGiven    Review[]  @relation("ReviewGiven")
  favorites       Favorite[]
}

model Challenge {
  nonce  String   @id
  pubkey String   @unique
  expiry DateTime
}

model Review {
  id             Int     @id @default(autoincrement())
  reviewedPubkey String
  reviewed       Account @relation("ReviewReceived", fields: [reviewedPubkey], references: [pubkey])
  reviewerPubkey String
  reviewer       Account @relation("ReviewGiven", fields: [reviewerPubkey], references: [pubkey])
  signature      String
  rating         Int
  message        String
  escrowAddress  String
  escrow         Escrow  @relation(fields: [escrowAddress], references: [address])

  @@unique([escrowAddress, reviewerPubkey])
}

model Listing {
  id           Int       @id @default(autoincrement())
  sellerPubkey String
  seller       Account   @relation(fields: [sellerPubkey], references: [pubkey])
  signature    String
  name         String
  description  String?
  price        Int
  createdAt    DateTime  @default(now())
  // categoryId is the authoritative single-category relation for a listing
  categoryId   Int?
  category     Category? @relation("ListingDirectCategory", fields: [categoryId], references: [id])

  // categories (ListingCategory) is a denormalized ancestry index: stores the listing's direct categoryId plus all ancestor category IDs, enabling efficient subtree filtering
  categories ListingCategory[]
  chats      Chat[]
  attributes ListingAttribute[]
  favorites  Favorite[]

  @@index([categoryId])
  @@index([price])
  @@index([sellerPubkey])
}

model ListingCategory {
  listingId  Int
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([listingId, categoryId])
  @@index([categoryId])
}

enum ChatStatus {
  open
  closed
}

enum EscrowStatus {
  awaitingFunds
  partiallyFunded
  fundLocked
  sellerReady
  buyerSubmitted
  buyerCheckpointsSigned
  completed
  refunded
}

model Chat {
  id            Int        @id @default(autoincrement())
  listingId     Int
  listing       Listing    @relation(fields: [listingId], references: [id])
  buyerPubkey   String
  buyer         Account    @relation("ChatBuyer", fields: [buyerPubkey], references: [pubkey])
  arbiterPubkey String?
  arbiter       Account?   @relation("ChatArbiter", fields: [arbiterPubkey], references: [pubkey])
  signature     String
  status        ChatStatus @default(open)
  createdAt     DateTime   @default(now())

  messages Message[]

  escrow Escrow?
}

model Message {
  id           Int      @id @default(autoincrement())
  chatId       Int
  chat         Chat     @relation(fields: [chatId], references: [id])
  message      String?
  senderPubkey String?
  sender       Account? @relation(fields: [senderPubkey], references: [pubkey])
  signature    String?
  isSystem     Boolean  @default(false)
  sentAt       DateTime @default(now())

  offer Offer?
}

model Offer {
  id        Int      @id @default(autoincrement())
  messageId Int      @unique
  message   Message  @relation(fields: [messageId], references: [id])
  price     Int
  valid     Boolean  @default(true)
  createdAt DateTime @default(now())

  acceptance OfferAcceptance? @relation("OfferToAcceptance")
  escrow     Escrow?
}

model OfferAcceptance {
  id        Int      @id @default(autoincrement())
  offerId   Int      @unique
  offer     Offer    @relation("OfferToAcceptance", fields: [offerId], references: [id])
  signature String
  accepted  Boolean
  createdAt DateTime @default(now())
}

model Category {
  id         Int        @id @default(autoincrement())
  name       String
  slug       String     @unique
  iconName   String?
  color      String?
  childrenOf Int?
  parent     Category?  @relation("CategoryTree", fields: [childrenOf], references: [id])
  children   Category[] @relation("CategoryTree")

  listings           ListingCategory[]
  directListings     Listing[]         @relation("ListingDirectCategory")
  categoryAttributes CategoryAttribute[]
}

model Attribute {
  id        Int           @id @default(autoincrement())
  name      String
  slug      String        @unique
  type      AttributeType

  rangeMin  Float?
  rangeMax  Float?
  rangeStep Float?
  rangeUnit String?

  values     AttributeValue[]
  categories CategoryAttribute[]
  listings   ListingAttribute[]
}

enum AttributeType {
  select
  boolean
  text
  range
  date
  multi_select
}

model AttributeValue {
  id          Int       @id @default(autoincrement())
  value       String
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id])

  listings            ListingAttribute[]
  multiSelectListings ListingAttributeValue[]
}

model CategoryAttribute {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  attributeId Int

  category  Category  @relation(fields: [categoryId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  required     Boolean @default(false)
  isFilterable Boolean @default(true)

  @@unique([categoryId, attributeId])
}

model ListingAttribute {
  id          Int      @id @default(autoincrement())
  listingId   Int
  attributeId Int
  valueId     Int?
  valueBool   Boolean?
  valueText   String?
  valueFloat  Float?

  listing     Listing                @relation(fields: [listingId], references: [id])
  attribute   Attribute              @relation(fields: [attributeId], references: [id])
  value       AttributeValue?        @relation(fields: [valueId], references: [id])
  multiValues ListingAttributeValue[]

  @@unique([listingId, attributeId])
  @@index([listingId])
  @@index([attributeId])
  @@index([valueId])
  @@index([valueFloat])
}

model ListingAttributeValue {
  id                 Int    @id @default(autoincrement())
  listingAttributeId Int
  valueId            Int

  listingAttribute ListingAttribute @relation(fields: [listingAttributeId], references: [id], onDelete: Cascade)
  value            AttributeValue   @relation(fields: [valueId], references: [id])

  @@unique([listingAttributeId, valueId])
  @@index([listingAttributeId])
  @@index([valueId])
}

model Escrow {
  address                 String       @id
  buyerPubkey             String
  buyer                   Account      @relation("EscrowBuyer", fields: [buyerPubkey], references: [pubkey])
  sellerPubkey            String
  seller                  Account      @relation("EscrowSeller", fields: [sellerPubkey], references: [pubkey])
  serverPubkey            String
  arbiterPubkey           String?
  arbiter                 Account?     @relation("EscrowArbiter", fields: [arbiterPubkey], references: [pubkey])
  price                   Int
  timelockExpiry          Int
  chatId                  Int          @unique
  chat                    Chat         @relation(fields: [chatId], references: [id])
  offerId                 Int?         @unique
  offer                   Offer?       @relation(fields: [offerId], references: [id])
  status                  EscrowStatus @default(awaitingFunds)
  sellerSignedCollabPsbt  String?
  collabArkTxid           String?
  serverSignedCheckpoints String?
  buyerSignedCheckpoints  String?
  createdAt               DateTime     @default(now())
  fundedAt                DateTime?
  releasedAt              DateTime?

  reviews Review[]
}

model Favorite {
  id            Int      @id @default(autoincrement())
  accountPubkey String
  account       Account  @relation(fields: [accountPubkey], references: [pubkey])
  listingId     Int
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([accountPubkey, listingId])
  @@index([accountPubkey])
  @@index([listingId])
}
